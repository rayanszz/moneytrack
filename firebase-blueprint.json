{
  "collections": [
    {
      "collectionName": "users",
      "documentId": "userId",
      "rules": [
        {
          "condition": "request.auth != null && request.auth.uid == userId",
          "allow": ["read", "write"]
        }
      ],
      "fields": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "avatarUrl": { "type": "string", "optional": true },
        "theme": { "type": "string" },
        "currency": { "type": "string" },
        "language": { "type": "string" },
        "pushNotifications": { "type": "boolean" },
        "emailAlerts": { "type": "boolean" },
        "budgetLimit": { "type": "number", "optional": true },
        "budgetSpent": { "type": "number", "optional": true }
      },
      "subcollections": [
        {
          "collectionName": "transactions",
          "documentId": "transactionId",
          "rules": [
            {
              "condition": "request.auth != null && request.auth.uid == userId",
              "allow": ["read", "write"]
            }
          ],
          "fields": {
            "merchant": { "type": "string" },
            "amount": { "type": "number" },
            "category": { "type": "string" },
            "date": { "type": "string" },
            "time": { "type": "string" },
            "paymentMethod": { "type": "string" },
            "type": { "type": "string" },
            "notes": { "type": "string", "optional": true },
            "items": { "type": "array", "optional": true }
          }
        },
        {
          "collectionName": "assets",
          "documentId": "assetId",
          "rules": [
            {
              "condition": "request.auth != null && request.auth.uid == userId",
              "allow": ["read", "write"]
            }
          ],
          "fields": {
            "name": { "type": "string" },
            "type": { "type": "string" },
            "value": { "type": "number" },
            "changePercent": { "type": "number" },
            "changeType": { "type": "string" },
            "allocationPercent": { "type": "number" },
            "countLabel": { "type": "string" },
            "ticker": { "type": "string", "optional": true },
            "sparkline": { "type": "array", "optional": true }
          }
        },
        {
          "collectionName": "scenarios",
          "documentId": "scenarioId",
          "rules": [
            {
              "condition": "request.auth != null && request.auth.uid == userId",
              "allow": ["read", "write"]
            }
          ],
          "fields": {
            "name": { "type": "string" },
            "monthlyContribution": { "type": "number" },
            "expectedYield": { "type": "number" },
            "timeHorizon": { "type": "number" },
            "totalContributions": { "type": "number" },
            "estimatedReturns": { "type": "number" },
            "estimatedFutureWealth": { "type": "number" },
            "dateCreated": { "type": "string" }
          }
        }
      ]
    }
  ]
}
